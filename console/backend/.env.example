# 复制为 backend/.env 后填写（勿提交）

# 要写入的表格 ID（与前端 VITE_GOOGLE_SHEET_ID 相同）
GOOGLE_SHEET_ID=

# Google Cloud Console → API → 凭据 → OAuth 2.0 客户端 ID（类型：Web 应用）
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 须与 Console 里「已授权的重定向 URI」完全一致（默认对应本仓库 README 的 8765 端口）
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/api/sheets/oauth/callback

# 可选：工作表 Tab 名（默认 Round1Audience / Round2Audience）
# GOOGLE_SHEET_ROUND1_TAB=Round1Audience
# GOOGLE_SHEET_ROUND2_TAB=Round2Audience
# GOOGLE_SHEET_ROUND3_TAB=Round3Audience

# 现场签到 POST /api/checkin：追加行到表格（须先在同一张表里新建同名 Tab；OAuth 同 GOOGLE_SHEET_ID）
# 建议列顺序：时间 UTC | 姓名 | 邮箱 | 趣味问答（选填）| 投票码 | 各轮链接文本
# GOOGLE_SHEET_CHECKIN_TAB=CheckIn

# 票码池 CSV（默认：仓库 console/firebase-vote/data/vote-codes.csv，仅当 checkin_pool 表为空时导入）
# CHECKIN_CODES_CSV=

# 签到成功后拼投票页（无尾斜杠）；须与 public/vote 页面路径一致
# VOTE_PAGE_BASE_URL=https://你的站点/vote/vote.html
#
# 各环节各生成一条链接（roundId + voteCode）。逗号分隔；不填则默认与 vote-app.js ALLOWED_ROUND_IDS 相同的 12 个轮次
# VOTE_CHECKIN_ROUND_IDS=round1_pk_1,round1_pk_2,round2_revival,final_perf_1
# 兼容旧配置：仅单轮时仍可用（会只发一条链接）
# VOTE_CHECKIN_ROUND_ID=round2_revival

# 邮件二选一：Resend（推荐）或 SMTP
# RESEND_API_KEY=
# RESEND_FROM=noreply@你的域名
# 默认 1：对 Resend API 强制 IPv4，避免 Docker/Railway 无 IPv6 路由时出现 [Errno 101] Network is unreachable
# RESEND_FORCE_IPV4=1
# CHECKIN_EMAIL_SUBJECT=Voice of NYC · 签到成功

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_TLS=1
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# 连接/读写超时（秒），避免 PaaS 上连不上 Gmail 时整请求一直挂起
# SMTP_TIMEOUT_SEC=45

# 前端托管在 Vercel 等外域时，须允许浏览器跨域访问本 API（逗号分隔、无空格或自行 trim）
# 例：CORS_EXTRA_ORIGINS=https://你的项目.vercel.app
# 或批量预览域名（正则，与 allow_origins 同时生效）：
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
